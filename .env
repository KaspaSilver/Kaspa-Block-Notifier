# ── kaspa-block-notifier / .env ───────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Your mining wallet address (the one that receives block rewards)
MINING_ADDRESS=
# The private key (hex) of the wallet that will SEND the KaChat notification tx.
# Keep this secret — it controls spending from that wallet.
PRIVATE_KEY_HEX=

# Address that will RECEIVE the KaChat notification
NOTIFY_ADDRESS=

# Network: mainnet or testnet-10
KASPA_NETWORK=mainnet

# Amount to send with each notification (in sompi, 1 KAS = 100_000_000 sompi)
NOTIFY_AMOUNT_SOMPI=2000000

# Only send a notification if the block reward is at least this many KAS.
# Useful to filter out orphaned or very small rewards.
# Set to 0 to alert on every UTXO received.
MIN_REWARD_KAS=0


BOT_ALIAS=
RECEIVER_ALIAS=
RECEIVER_PUBKEY_X=
